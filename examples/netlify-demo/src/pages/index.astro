---
import Search from '../components/Search.vue';
import { getCollection } from 'astro:content';

// Build a corpus list straight from the same content collection the
// integration walks. That way the "what's in the search index" section
// stays in sync with whatever PDFs are actually indexed at build time.
const docs = await getCollection('docs');

type CorpusItem = {
  title: string;
  filename: string;
  publicUrl: string;
  pdfBytes: number;
  pages: number | null;
  textChars: number;
};

// Pull the JSON index that the Astro PDF integration writes into
// public/. We import the file via Node's fs at build time so we can read
// page counts and extracted-text length without bundling the data into
// JS. This file is regenerated on every build.
import { readFile } from 'node:fs/promises';
import { readdirSync, statSync } from 'node:fs';
import { resolve } from 'node:path';

let indexRows: Array<{ id: string; url: string; title: string; text: string; pages?: number }> =
  [];
try {
  const json = await readFile(
    resolve(import.meta.dirname, '..', '..', 'public', 'searchIndex.pdfs.json'),
    'utf-8',
  );
  indexRows = JSON.parse(json);
} catch {
  // First-pass dev render before the integration has written the file
  // — leave the list empty; HMR will fill it in on next build.
  indexRows = [];
}

const pdfsDir = resolve(import.meta.dirname, '..', '..', 'public', 'pdfs');
const pdfBytesByFilename = new Map<string, number>();
try {
  for (const entry of readdirSync(pdfsDir)) {
    if (!entry.toLowerCase().endsWith('.pdf')) continue;
    pdfBytesByFilename.set(entry, statSync(resolve(pdfsDir, entry)).size);
  }
} catch {
  /* dir may not exist on first cold run */
}

function basenameFromFileUrl(fileUrl: string): string {
  const lastSlash = fileUrl.lastIndexOf('/');
  return decodeURIComponent(lastSlash >= 0 ? fileUrl.slice(lastSlash + 1) : fileUrl);
}

function formatBytes(n: number): string {
  if (!n) return '—';
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(0)} KB`;
  return `${(n / 1024 / 1024).toFixed(1)} MB`;
}

const corpus: CorpusItem[] = indexRows
  .map((row) => {
    const filename = basenameFromFileUrl(row.url);
    return {
      title: row.title,
      filename,
      publicUrl: `/pdfs/${encodeURIComponent(filename)}`,
      pdfBytes: pdfBytesByFilename.get(filename) ?? 0,
      pages: row.pages ?? null,
      textChars: row.text?.length ?? 0,
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));

const pdfCount = corpus.length || docs.length;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PDF Search Index — Live Demo</title>
    <meta
      name="description"
      content="Live demo of @icjia/pdf-search-index — full-text search across PDFs at build time. No server, no native deps."
    />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <style is:global>
      :root {
        --bg: #0a0a0c;
        --surface: #15151a;
        --surface-hover: #1d1d24;
        --border: #27272f;
        --border-strong: #3a3a44;
        --text: #e8e8ed;
        --text-muted: #a0a0aa;
        --text-placeholder: #6f6f7a;
        --accent: #7c9eff;
        --font-sans:
          'Inter', 'SF Pro Text', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', Menlo, Consolas, 'Roboto Mono', monospace;
        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 2px;
      }

      code,
      kbd,
      pre {
        font-family: var(--font-mono);
      }
      code {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 0.1em 0.35em;
        border-radius: 4px;
        font-size: 0.88em;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        z-index: 999;
      }
      .skip-link:focus {
        left: 1rem;
        top: 1rem;
        padding: 0.5rem 0.75rem;
        background: var(--surface);
        border: 2px solid var(--accent);
        border-radius: 4px;
        color: var(--text);
        text-decoration: none;
      }
    </style>
    <style>
      /*
       * Edge-to-edge layout: the wrap fills the viewport width with side
       * padding rather than being a narrow centered column. Prose blocks
       * inside still have their own max-width (set on <p>) so long lines
       * stay readable, but cards (search, tune, why, index) stretch.
       */
      .wrap {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        padding: 3rem 1.25rem 0;
      }
      main.wrap {
        padding-bottom: 0;
      }
      footer.wrap {
        padding-bottom: 3rem;
      }
      @media (min-width: 768px) {
        .wrap {
          padding-left: 2.5rem;
          padding-right: 2.5rem;
        }
        main.wrap {
          padding-top: 4rem;
        }
        footer.wrap {
          padding-bottom: 4rem;
        }
      }
      @media (min-width: 1280px) {
        .wrap {
          padding-left: 4rem;
          padding-right: 4rem;
        }
      }

      header.site {
        margin-bottom: 2.5rem;
      }

      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin: 0 0 0.75rem;
      }

      h1.site-title {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 0.75rem;
        line-height: 1.15;
      }

      p.site-tagline {
        font-size: clamp(1rem, 2vw, 1.125rem);
        color: var(--text-muted);
        margin: 0;
        max-width: 60ch;
      }

      section {
        margin-top: 3rem;
      }

      h2 {
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 0 0 1rem;
      }

      p {
        margin: 0 0 1rem;
        max-width: 65ch;
        color: var(--text);
      }
      p.muted {
        color: var(--text-muted);
      }

      ol.steps {
        list-style: none;
        counter-reset: step;
        padding: 0;
        margin: 1rem 0 0;
        display: grid;
        gap: 1rem;
      }
      ol.steps > li {
        counter-increment: step;
        position: relative;
        padding: 1rem 1.25rem 1rem 3.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
      }
      ol.steps > li::before {
        content: counter(step);
        position: absolute;
        left: 1rem;
        top: 1rem;
        width: 1.75rem;
        height: 1.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        border-radius: 6px;
      }
      ol.steps > li strong {
        display: block;
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
        font-weight: 600;
      }
      ol.steps > li p {
        margin: 0;
        font-size: 0.92rem;
        color: var(--text-muted);
      }

      ul.corpus {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
        display: grid;
        gap: 0.75rem;
      }
      ul.corpus > li {
        padding: 1.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        transition: border-color 150ms ease;
      }
      ul.corpus > li:hover {
        border-color: var(--border-strong);
      }
      .corpus__title {
        margin: 0 0 0.4rem;
        font-size: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
      }
      .corpus__badge {
        display: inline-flex;
        align-items: center;
        padding: 0.15rem 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        border-radius: 4px;
        border: 1px solid;
      }
      .corpus__badge--ocr {
        color: #fbbf24;
        background: rgba(251, 191, 36, 0.08);
        border-color: rgba(251, 191, 36, 0.35);
      }
      .corpus__note code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        background: var(--surface);
        padding: 0.05em 0.35em;
        border-radius: 3px;
        border: 1px solid var(--border);
      }
      .corpus__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        margin: 0 0 0.6rem;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      .corpus__meta span::before {
        content: '';
        display: inline-block;
        width: 4px;
        height: 4px;
        margin-right: 0.5em;
        background: var(--border-strong);
        border-radius: 50%;
        vertical-align: middle;
      }
      .corpus__note {
        margin: 0;
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .corpus__note a {
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }
      .corpus__cta {
        display: inline-flex;
        margin-top: 0.5rem;
        font-size: 0.88rem;
        font-weight: 500;
      }
      .corpus__cta::after {
        content: '\2192';
        margin-left: 0.4em;
      }

      footer.site {
        margin-top: 5rem;
        padding-top: 2.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .footer__chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 0.95rem;
        font-size: 0.88rem;
        font-weight: 500;
        color: var(--text-muted);
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 999px;
        text-decoration: none;
        transition:
          background 150ms ease,
          border-color 150ms ease,
          color 150ms ease,
          transform 150ms ease;
        white-space: nowrap;
      }

      .footer__chip:hover {
        color: var(--text);
        background: var(--surface);
        border-color: var(--border-strong);
        text-decoration: none;
      }

      .footer__chip:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        color: var(--text);
      }

      .footer__chip svg {
        flex-shrink: 0;
      }

      @media (max-width: 480px) {
        footer.site {
          gap: 0.5rem;
          padding-top: 2rem;
        }
        .footer__chip {
          padding: 0.5rem 0.75rem;
          font-size: 0.85rem;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main" class="wrap">
      <header class="site">
        <p class="eyebrow">@icjia/pdf-search-index</p>
        <h1 class="site-title">pdf-search-index — live demo</h1>
        <p class="site-tagline">
          Full-text search across PDFs at build time. No server, no native deps.
        </p>
      </header>

      <section aria-labelledby="what">
        <h2 id="what">What this is</h2>
        <p>
          This is a live deployment of the open-source <code>@icjia/pdf-search-index</code> package.
          The {pdfCount} PDFs below were fetched and parsed at build time; their full text is
          searchable client-side via Fuse.js — no database, no API, no runtime indexing.
        </p>
      </section>

      <section aria-labelledby="how">
        <h2 id="how">How it works</h2>
        <ol class="steps">
          <li>
            <strong>Extract</strong>
            <p>
              At build time, each PDF is fetched, parsed with <code>pdf.js</code>, and its text is
              added to a JSON index.
            </p>
          </li>
          <li>
            <strong>Bundle</strong>
            <p>
              The JSON ships with the site as a static asset — no API, no server, no database.
            </p>
          </li>
          <li>
            <strong>Search</strong>
            <p>
              Your query runs client-side against Fuse.js. The matching span is highlighted in the
              snippet below each result.
            </p>
          </li>
        </ol>
      </section>

      <section aria-labelledby="corpus">
        <h2 id="corpus">The corpus</h2>
        <p class="muted">
          The {pdfCount} PDFs indexed by this build, with their on-disk size, page count, and the number
          of characters of plain text extracted from each one.
        </p>
        <ul class="corpus">
          {
            corpus.map((p) => (
              <li>
                <h3 class="corpus__title">
                  {p.title}
                  {p.textChars < 50 && (
                    <span
                      class="corpus__badge corpus__badge--ocr"
                      title="This PDF has no text layer — it's image-only or a scan. The package extracts no body text from it; Fuse can still match against the title. Run ocrmypdf on the source to add searchable body text."
                    >
                      Needs OCR — title only
                    </span>
                  )}
                </h3>
                <p class="corpus__meta">
                  {p.pages !== null && <span>{p.pages} pages</span>}
                  <span>{formatBytes(p.pdfBytes)}</span>
                  <span>{p.textChars.toLocaleString()} characters extracted</span>
                </p>
                <p class="corpus__note">
                  Randomly-clicked public sample from{' '}
                  <a href="https://icjia.illinois.gov/" target="_blank" rel="noopener noreferrer">
                    icjia.illinois.gov
                  </a>
                  ; contains no PII.
                  {p.textChars < 50 && (
                    <>
                      {' '}
                      This one is image-only — the extractor returns empty text and Fuse can't match it.
                      Run <code>ocrmypdf</code> on the source PDF first to add a searchable text layer;
                      this package then indexes it normally on the next build.
                    </>
                  )}
                </p>
                <a
                  class="corpus__cta"
                  href={p.publicUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  View PDF
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <Search client:idle />
    </main>

    <footer class="site wrap" aria-label="External links">
        <a
          class="footer__chip"
          href="https://github.com/ICJIA/pdf-search-index"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="16"
            height="16"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
          <span>GitHub</span>
        </a>
        <a
          class="footer__chip"
          href="https://www.npmjs.com/package/@icjia/pdf-search-index"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="16"
            height="16"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331zM10.665 10H12v2.667h-1.335V10z"
            ></path>
          </svg>
          <span>npm</span>
        </a>
        <a
          class="footer__chip"
          href="https://github.com/ICJIA/pdf-search-index/blob/main/packages/core/CHANGELOG.md"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            width="16"
            height="16"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"
            ></path>
            <rect x="9" y="3" width="6" height="4" rx="1"></rect>
            <path d="M9 12h6M9 16h4"></path>
          </svg>
          <span>Changelog</span>
        </a>
        <a
          class="footer__chip"
          href="https://github.com/ICJIA/pdf-search-index/blob/main/docs/superpowers/specs/2026-05-15-pdf-search-index-design.md"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            width="16"
            height="16"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="8" y1="13" x2="16" y2="13"></line>
            <line x1="8" y1="17" x2="16" y2="17"></line>
            <line x1="8" y1="9" x2="10" y2="9"></line>
          </svg>
          <span>Design spec</span>
        </a>
    </footer>
  </body>
</html>
